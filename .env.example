# Apify - Get your token from https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# OpenAI - For accurate lead classification (seeking vs building/promoting)
# Get key from https://platform.openai.com/api-keys
# Without this, falls back to keyword filter (less accurate)
OPENAI_API_KEY=sk-your_openai_key_here

# Email (Gmail example - use App Password, not regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_TO=your_email@gmail.com

# Optional: scrape window & freshness (defaults shown)
# DATE_FILTER=past-24h
# RECENT_POST_MAX_HOURS=2
# INCLUDE_POST_IF_DATE_MISSING=false
